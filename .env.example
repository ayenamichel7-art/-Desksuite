# ========================================
# 🧠 Desksuite — Environment Variables Template
# ========================================
# IMPORTANT: Copy this file to .env and fill in your real values.
# NEVER commit the .env file itself.

# --- 🧠 App Config ---
APP_NAME=Desksuite
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://desksuite.localhost:8081

# --- 🗄️ Database ---
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=desksuite
DB_USERNAME=your_db_user
DB_PASSWORD=your_strong_db_password

# --- 🚀 Redis / Queues ---
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=predis
INTERNAL_API_TOKEN=generate_a_strong_random_token_here

# --- 📦 Storage (MinIO) ---
FILESYSTEM_DISK=s3
MINIO_ROOT_USER=your_minio_user
MINIO_ROOT_PASSWORD=your_minio_password
S3_ACCESS_KEY_ID=your_minio_user
S3_SECRET_ACCESS_KEY=your_minio_password
S3_REGION=us-east-1
S3_BUCKET=desksuite
S3_URL=http://desksuite.localhost:8081/storage
S3_ENDPOINT=http://minio:9000
S3_USE_PATH_STYLE_ENDPOINT=true

# --- 🛡️ Cloudflare Zero Trust ---
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token

# --- 🤖 Telegram Integration ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_CHAT_ID=your_telegram_chat_id
PYTHON_WORKER_URL=http://python-worker:5000

# --- ⚡ Octane (Swoole) ---
OCTANE_SERVER=swoole
OCTANE_PORT=8000

# --- 📡 Reverb (WebSockets) ---
REVERB_APP_ID=846522
REVERB_APP_KEY=generate_a_reverb_key
REVERB_APP_SECRET=generate_a_reverb_secret

# --- 🌐 Nginx ---
NGINX_PORT=8081
